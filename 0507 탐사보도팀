<script>
/* ── 스크롤 reveal ── */
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

/* ── 배너 ── */
const crisisBar = document.getElementById('crisisBar');
const crisisClose = document.getElementById('crisisClose');
let bannerShown = false;
window.addEventListener('scroll', () => {
  if(!bannerShown && window.scrollY > 10){ crisisBar.classList.add('visible'); bannerShown = true; }
}, { passive: true });
crisisClose.addEventListener('click', () => { crisisBar.style.transform = 'translateY(100%)'; });

/* ── 숫자 카운터 애니메이션 ── */
function animateCounter(el, target, duration, isDecimal, prefix, suffix) {
  const start = performance.now();
  const update = (now) => {
    const progress = Math.min((now - start) / duration, 1);
    // easeOutExpo
    const ease = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
    let val = target * ease;
    let display;
    if (isDecimal) {
      display = (val / 10).toFixed(1) + suffix;
    } else {
      display = prefix + Math.floor(val).toLocaleString('ko-KR') + suffix;
    }
    el.textContent = display;
    if (progress < 1) requestAnimationFrame(update);
    else {
      if (isDecimal) el.textContent = (target/10).toFixed(1) + suffix;
      else el.textContent = prefix + target.toLocaleString('ko-KR') + suffix;
    }
  };
  requestAnimationFrame(update);
}

const numberObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const card = e.target;
      card.classList.add('counted');
      const cards = document.querySelectorAll('.number-card');
      cards.forEach((c, i) => {
        const target = parseInt(c.dataset.target);
        const suffix = c.dataset.suffix || '';
        const prefix = c.dataset.prefix || '';
        const isDecimal = !!c.dataset.decimal;
        const el = document.getElementById('num' + i);
        setTimeout(() => animateCounter(el, target, 2000, isDecimal, prefix, suffix), i * 200);
        c.classList.add('counted');
      });
      numberObs.disconnect();
    }
  });
}, { threshold: 0.3 });
const numbersSection = document.getElementById('numbers');
if (numbersSection) numberObs.observe(numbersSection);

/* ── 그래프 선 드로우 애니메이션 ── */
const chartLine = document.getElementById('chartLine');
if (chartLine && chartLine.getTotalLength) {
  const len = chartLine.getTotalLength();
  chartLine.style.strokeDasharray = len;
  chartLine.style.strokeDashoffset = len;
  chartLine.style.transition = 'stroke-dashoffset 2.2s cubic-bezier(0.4,0,0.2,1)';
}
const chartObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting && chartLine) {
      chartLine.style.strokeDashoffset = 0;
      chartObs.unobserve(e.target);
    }
  });
}, { threshold: 0.3 });
const chartSection = document.getElementById('chart');
if (chartSection) chartObs.observe(chartSection);

/* ── 그래프 툴팁 ── */
const tooltip = document.getElementById('chartTooltip');
const svgEl = document.getElementById('lineChartSvg');
document.querySelectorAll('.chart-hit').forEach(hit => {
  hit.style.cursor = 'pointer';
  const showTip = (e) => {
    const svgRect = svgEl.getBoundingClientRect();
    const wrapRect = svgEl.parentElement.getBoundingClientRect();
    const svgW = svgRect.width;
    const viewW = 900;
    const scale = svgW / viewW;
    const cx = parseFloat(hit.dataset.cx) * scale;
    const cy = parseFloat(hit.dataset.cy) * scale;
    tooltip.textContent = hit.dataset.year + '년  ' + hit.dataset.val + '명';
    tooltip.style.left = (cx) + 'px';
    tooltip.style.top  = (cy) + 'px';
    tooltip.classList.add('show');
  };
  hit.addEventListener('mouseenter', showTip);
  hit.addEventListener('touchstart', showTip, { passive: true });
  hit.addEventListener('mouseleave', () => tooltip.classList.remove('show'));
  hit.addEventListener('touchend', () => setTimeout(() => tooltip.classList.remove('show'), 1500));
});
</script>
