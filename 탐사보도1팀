<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>자살예방법 4조, 국가의 책무 — 세계일보 탐사보도팀</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Serif+KR:wght@300;400;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0e0e0e;
    --off-white: #ffffff;
    --warm-green: #009e2f;
    --accent: #009e2f;
    --text: #1a1a1a;
    --muted: #6b6560;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--off-white);
    color: var(--text);
    font-family: 'Noto Serif KR', serif;
    overflow-x: hidden;
  }

  /* ─── 자살예방 고정 배너 ─── */
  .crisis-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(6px);
    border-top: 1px solid rgba(0, 158, 47, 0.4);
    padding: 0.75rem 2.8rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transform: translateY(100%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .crisis-bar.visible {
    transform: translateY(0);
  }

  .crisis-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border: 1.5px solid var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .crisis-icon::after {
    content: '※';
    font-size: 0.55rem;
    color: var(--accent);
    line-height: 1;
  }

  .crisis-text {
    font-family: 'Noto Serif KR', serif;
    font-size: 0.72rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 300;
    flex: 1;
  }

  .crisis-text strong {
    color: var(--accent);
    font-weight: 600;
  }

  .crisis-close {
    flex-shrink: 0;
    background: none;
    border: none;
    color: rgba(255,255,255,0.35);
    font-size: 1rem;
    cursor: pointer;
    padding: 0.2rem 0.4rem;
    line-height: 1;
    transition: color 0.2s;
  }

  .crisis-close:hover { color: rgba(255,255,255,0.7); }

  @media (max-width: 640px) {
    .crisis-bar { padding: 0.8rem 1.2rem; gap: 0.7rem; }
    .crisis-text { font-size: 0.65rem; }
    .crisis-icon { display: none; }
  }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('hero.jpg') center/cover no-repeat;
    filter: brightness(0.52);
    transform: scale(1.04);
    animation: heroZoom 14s ease-out forwards;
  }

  @keyframes heroZoom {
    from { transform: scale(1.04); }
    to   { transform: scale(1.0); }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 2.8rem 5rem;
    max-width: 900px;
    opacity: 0;
    transform: translateY(24px);
    animation: fadeUp 1s 0.5s ease forwards;
  }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn { to { opacity: 1; } }

  .hero-label {
    font-family: 'Noto Serif KR', serif;
    font-size: clamp(1rem, 2.2vw, 1.5rem);
    font-weight: 300;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.82);
    margin-bottom: 1.2rem;
  }

  .hero-title {
    font-family: 'Noto Serif KR', serif;
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    font-weight: 450;
    color: #fff;
    line-height: 1.05;
    margin-bottom: 0.8rem;
    letter-spacing: -0.01em;
  }

  .hero-subtitle {
    font-family: 'Noto Serif KR', serif;
    font-size: clamp(0.95rem, 1.8vw, 1.2rem);
    color: rgba(255,255,255,0.55);
    font-weight: 300;
    letter-spacing: 0.06em;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2.2rem;
    right: 2.8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeIn 1s 1.4s forwards;
  }

  .scroll-indicator span {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.4);
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 52px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.45), transparent);
    animation: scrollPulse 2.2s infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 1; }
  }

  /* ─── LEAD ─── */
  .lead-section {
    padding: 7rem 2.8rem 6rem;
    max-width: 820px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .lead-section.visible { opacity: 1; transform: translateY(0); }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 2rem;
  }

  .lead-section h2 {
    font-family: 'Noto Serif KR', serif;
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 600;
    line-height: 1.6;
    margin-bottom: 2rem;
    color: var(--black);
    border-left: 3px solid var(--accent);
    padding-left: 1.4rem;
  }

  .lead-text {
    font-size: 1rem;
    line-height: 2.1;
    color: var(--muted);
    font-weight: 300;
  }

  .lead-text p + p { margin-top: 1.2rem; }

  /* ─── DIVIDER ─── */
  .divider {
    height: 1px;
    background: linear-gradient(to right, transparent, #009e2f, transparent);
    margin: 0 2.8rem;
  }

  /* ─── SERIES ─── */
  .series-section {
    padding: 6rem 2.8rem;
    max-width: 1100px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .series-section.visible { opacity: 1; transform: translateY(0); }

  .series-section > .section-label { margin-bottom: 0.4rem; }

  .series-section > h2 {
    font-family: 'Noto Serif KR', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 600;
    margin-bottom: 2.8rem;
    color: var(--black);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .card {
    position: relative;
    aspect-ratio: 16/10;
    border-radius: 3px;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-size: cover;
    background-position: center;
    transition: transform 0.55s ease;
  }

  .card:hover .card-img { transform: scale(1.04); }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.15) 55%, transparent 100%);
    transition: background 0.4s;
  }

  .card:hover .card-overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.3) 55%, transparent 100%);
  }

  .card-body {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 1.6rem 1.4rem;
  }

  .card-num {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;        /* ↑ 키움 */
    letter-spacing: 0.18em;
    color: var(--accent);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  .card-title {
    font-family: 'Noto Serif KR', serif;
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);   /* ↑ 키움 */
    font-weight: 600;
    color: #fff;
    line-height: 1.55;
    margin-bottom: 0.6rem;
  }

  .card-link-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;        /* ↑ 키움 */
    letter-spacing: 0.15em;
    color: var(--accent);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.3s, transform 0.3s;
  }

  .card:hover .card-link-label { opacity: 1; transform: translateY(0); }
  .card-link-label::after { content: '→'; font-size: 0.9rem; }

  .img-1 { background-image: url('./images/thumb1.jpg'); }
  .img-2 { background-image: url('./images/thumb2.jpeg'); }
  .img-3 { background-image: url('./images/thumb3.jpg'); }
  .img-4 { background-image: url('./images/thumb4.jpg'); }

  /* ─── CREDITS ─── */
  .credits-section {
    padding: 5.5rem 2.8rem 7rem;   /* 하단 배너 공간 확보 */
    background: var(--black);
    color: var(--off-white);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .credits-section.visible { opacity: 1; transform: translateY(0); }

  .credits-inner { max-width: 900px; margin: 0 auto; }

  .credits-section .section-label { color: var(--accent); }

  .credits-section h2 {
    font-family: 'Noto Serif KR', serif;
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 600;
    margin-bottom: 3.5rem;
    color: var(--off-white);
  }

  .credits-role-group { margin-bottom: 2.8rem; }

  .credits-role-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 0.5rem;
    margin-bottom: 1.2rem;
  }

  .credits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem 2rem;
  }

  .credit-name {
    font-family: 'Noto Serif KR', serif;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--off-white);
    margin-bottom: 0.2rem;
  }

  .credit-email {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    color: #009e2f;
    letter-spacing: 0.03em;
  }

  /* ─── FOOTER ─── */
  footer {
    background: var(--black);
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 1.8rem 2.8rem 4rem;  /* 배너 높이만큼 하단 여백 */
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-logo {
    font-family: 'Noto Serif KR', serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: #009e2f;
  }

  .footer-copy {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    color: rgba(255,255,255,0.22);
    letter-spacing: 0.1em;
  }

  /* ─── MOBILE ─── */
  @media (max-width: 640px) {
    .hero-content { padding: 0 1.4rem 3.5rem; }
    .hero-label { font-size: 0.85rem; letter-spacing: 0.1em; }
    .hero-title { font-size: clamp(2.4rem, 12vw, 3.5rem); }
    .lead-section { padding: 4rem 1.4rem 3.5rem; }
    .series-section { padding: 4rem 1.4rem; }
    .cards-grid { grid-template-columns: 1fr; }
    .card { aspect-ratio: 4/3; }
    .card-title { font-size: 1.1rem; }
    .credits-section { padding: 4rem 1.4rem 6rem; }
    .credits-grid { grid-template-columns: 1fr 1fr; }
    .divider { margin: 0 1.4rem; }
    footer { flex-direction: column; gap: 0.7rem; text-align: center; padding-bottom: 5rem; }
    .scroll-indicator { display: none; }
  }
</style>
</head>
<body>

<!-- ─── 자살예방 고정 배너 (첫 스크롤 후 등장) ─── -->
<div class="crisis-bar" id="crisisBar">
  <div class="crisis-icon"></div>
  <p class="crisis-text">
    우울감 등 말하기 어려운 고민이 있거나 주변에 이런 어려움을 겪는 가족·지인이 있을 경우
    <strong>자살예방 상담전화(109)</strong> 또는 자살예방 SNS상담 <strong>'마들랜'</strong>에서
    24시간 전문가의 상담을 받을 수 있습니다.
  </p>
  <button class="crisis-close" id="crisisClose" aria-label="닫기">✕</button>
</div>

<!-- ─── HERO ─── -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-label">세계일보 탐사보도팀</div>
    <h1 class="hero-title">자살예방법 제4조, 국가의 책무</h1>
    <p class="hero-subtitle">법의 그물 밖에서 — 제도가 놓친 죽음들</p>
  </div>
  <div class="scroll-indicator">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ─── LEAD ─── -->
<section class="lead-section" id="lead">
  <div class="section-label">— 들어가며</div>
  <h2>법이 닿지 않는 곳의 죽음들</h2>
  <div class="lead-text">
    <p>자살예방법이 시행된 지 10년이 넘었다. 그러나 법은 여전히 모든 죽음에 닿지 못한다. 온라인 플랫폼을 통해 유통되는 자살유발정보, 위기 상황에서 끊기는 인계 체계, 제도 바깥에 놓인 유가족들의 시간.</p>
    <p>세계일보 탐사보도팀은 법이 설계하지 못한 구멍을 따라갔다. 한 아버지의 기록에서 시작한 취재는 자살예방 시스템 전반의 구조적 실패로 이어졌다.</p>
    <p>이 시리즈는 그 그물 밖의 이야기다.</p>
  </div>
</section>

<div class="divider"></div>

<!-- ─── SERIES ─── -->
<section class="series-section" id="series">
  <div class="section-label">— Series</div>
  <h2>기사 모음</h2>

  <div class="cards-grid">

    <a class="card" href="#">
      <div class="card-img img-1"></div>
      <div class="card-overlay"></div>
      <div class="card-body">
        <div class="card-num">1화</div>
        <div class="card-title">아이디<br>'초록나무'의 아빠</div>
        <div class="card-link-label">기사 읽기</div>
      </div>
    </a>

    <a class="card" href="#">
      <div class="card-img img-2"></div>
      <div class="card-overlay"></div>
      <div class="card-body">
        <div class="card-num">2화</div>
        <div class="card-title">죽음을 유통한<br>'설연최'를 잡다</div>
        <div class="card-link-label">기사 읽기</div>
      </div>
    </a>

    <a class="card" href="#">
      <div class="card-img img-3"></div>
      <div class="card-overlay"></div>
      <div class="card-body">
        <div class="card-num">3화</div>
        <div class="card-title">사례관리자의<br>무게</div>
        <div class="card-link-label">기사 읽기</div>
      </div>
    </a>

    <a class="card" href="#">
      <div class="card-img img-4"></div>
      <div class="card-overlay"></div>
      <div class="card-body">
        <div class="card-num">4화</div>
        <div class="card-title">남겨진 사람들의<br>회복</div>
        <div class="card-link-label">기사 읽기</div>
      </div>
    </a>

  </div>
</section>

<div class="divider"></div>

<!-- ─── CREDITS ─── -->
<section class="credits-section" id="credits">
  <div class="credits-inner">
    <div class="section-label">— Team</div>
    <h2>제작한 사람들</h2>

    <div class="credits-role-group">
      <div class="credits-role-label">취재</div>
      <div class="credits-grid">
        <div class="credit-item">
          <div class="credit-name">조병욱 기자</div>
          <div class="credit-email">brightw@segye.com</div>
        </div>
        <div class="credit-item">
          <div class="credit-name">배주현 기자</div>
          <div class="credit-email">jhb92@segye.com</div>
        </div>
        <div class="credit-item">
          <div class="credit-name">정세진 기자</div>
          <div class="credit-email">oasis@segye.com</div>
        </div>
      </div>
    </div>

    <div class="credits-role-group">
      <div class="credits-role-label">편집·미술</div>
      <div class="credits-grid">
        <div class="credit-item">
          <div class="credit-name">이름 입력</div>
          <div class="credit-email"></div>
        </div>
      </div>
    </div>

    <div class="credits-role-group">
      <div class="credits-role-label">사진</div>
      <div class="credits-grid">
        <div class="credit-item">
          <div class="credit-name">이름 입력</div>
          <div class="credit-email"></div>
        </div>
      </div>
    </div>

    <div class="credits-role-group">
      <div class="credits-role-label">웹페이지 제작</div>
      <div class="credits-grid">
        <div class="credit-item">
          <div class="credit-name">이름 입력</div>
          <div class="credit-email"></div>
        </div>
      </div>
    </div>

  </div>
</section>

<footer>
  <span class="footer-logo">자살예방법</span>
  <span class="footer-copy">© 세계일보 탐사보도팀</span>
</footer>

<script>
  // ─── 스크롤 페이드인 ───
  const reveals = document.querySelectorAll('.lead-section, .series-section, .credits-section');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));

  // ─── 자살예방 배너: 첫 스크롤 시 등장, X버튼으로 닫기 ───
  const crisisBar = document.getElementById('crisisBar');
  const crisisClose = document.getElementById('crisisClose');
  let bannerShown = false;

  window.addEventListener('scroll', () => {
    if (!bannerShown && window.scrollY > 10) {
      crisisBar.classList.add('visible');
      bannerShown = true;
    }
  }, { passive: true });

  crisisClose.addEventListener('click', () => {
    crisisBar.style.transform = 'translateY(100%)';
  });
</script>
</body>
</html>
